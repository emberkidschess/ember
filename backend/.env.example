# Runtime
NODE_ENV=production
PORT=5001
LOG_LEVEL=info

# Rate limiting (requests per 15 minutes)
RATE_LIMIT_API_MAX=200
RATE_LIMIT_STRICT_MAX=50
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_CHAT_MAX=30

# Gemini chatbot and RAG index (server-side only)
# Create this key in Google AI Studio. Never expose it through NEXT_PUBLIC_*.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Retrieve only the most relevant chunks to keep prompts fast and inexpensive.
RAG_TOP_K=4
# Refresh changed public website/database content on demand at this interval.
RAG_REFRESH_MINUTES=15

# Database (required)
# Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/emberkids?retryWrites=true&w=majority

# Frontend origins allowed by CORS/CSRF. Use comma-separated origins when needed.
# For MilesWeb Shared Hosting: Frontend on emberkidschess.com, Backend on api.emberkidschess.com
FRONTEND_URL=https://emberkidschess.com,https://www.emberkidschess.com
# Use "none" for cross-site HTTPS frontend/backend deployment (different subdomains)
COOKIE_SAME_SITE=none

# Authentication (all required, all different; use 32+ random characters)
# Generate these using: openssl rand -base64 32
JWT_ACCESS_SECRET=generate_32_char_random_secret_here
JWT_REFRESH_SECRET=generate_32_char_random_secret_here
JWT_CLIENT_ACCESS_SECRET=generate_32_char_random_secret_here
JWT_CLIENT_REFRESH_SECRET=generate_32_char_random_secret_here

# Initial administrator bootstrap scripts only
# Replace with your actual admin credentials
ADMIN_EMAIL=hello@emberkidschess.com
ADMIN_PASSWORD=your_secure_admin_password_here

# Optional Redis cache. Recommended in production.
# Replace with your Redis provider URL (e.g., Redis Cloud, Upstash, etc.)
REDIS_URL=redis://your-redis-url

# Email (required for credentials, resets, invoices, and notifications)
# Replace with your actual SMTP provider details (e.g., Titan Email, SendGrid, etc.)
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=hello@emberkidschess.com
EMAIL_PASS=your_smtp_password_here
EMAIL_FROM="EmberKids Chess Academy <hello@emberkidschess.com>"

# Wise manual payment instructions
# Replace with your actual Wise payment details if using Wise
WISE_BUSINESS_NAME=EmberKids Chess Academy
WISE_RECIPIENT_NAME=your_wise_recipient_name
WISE_RECIPIENT_EMAIL=your_wise_recipient_email
WISE_PAYMENT_LINK=your_wise_payment_link

# WhatsApp delivery through Twilio (optional)
# Replace with your actual Twilio credentials if using WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=your_twilio_whatsapp_number

# File uploads through Cloudinary
# Replace with your actual Cloudinary credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Public contact details used when the site config is first created
PUBLIC_CONTACT_EMAIL=hello@emberkidschess.com
PUBLIC_CONTACT_PHONE=+91 88240 44647
PUBLIC_CONTACT_PHONE_HREF=tel:+918824044647
PUBLIC_WHATSAPP_URL=https://wa.me/918824044647
PUBLIC_INSTAGRAM_URL=https://www.instagram.com/emberkidsofficial

# Support email for help requests
SUPPORT_EMAIL=support@emberkidschess.com
