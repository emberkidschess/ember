# Runtime
NODE_ENV=production
PORT=5001
LOG_LEVEL=info

# Rate limiting (requests per 15 minutes)
RATE_LIMIT_API_MAX=200
RATE_LIMIT_STRICT_MAX=50
RATE_LIMIT_AUTH_MAX=50

# Database (required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/emberkids?retryWrites=true&w=majority

# Frontend origins allowed by CORS/CSRF. Use comma-separated origins when needed.
# For MilesWeb Shared Hosting: Frontend on emberkidschess.com, Backend on api.emberkidschess.com
FRONTEND_URL=https://emberkidschess.com,https://www.emberkidschess.com
# Use "none" for cross-site HTTPS frontend/backend deployment (different subdomains)
COOKIE_SAME_SITE=none

# Authentication (all required, all different; use 32+ random characters)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_CLIENT_ACCESS_SECRET=
JWT_CLIENT_REFRESH_SECRET=

# Initial administrator bootstrap scripts only
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Optional Redis cache. Recommended in production.
REDIS_URL=redis://127.0.0.1:6379

# Email (required for credentials, resets, invoices, and notifications)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=EmberKids Chess Academy <noreply@example.com>

# Wise manual payment instructions
WISE_BUSINESS_NAME=EmberKids Chess Academy
WISE_RECIPIENT_NAME=
WISE_RECIPIENT_EMAIL=
WISE_PAYMENT_LINK=

# WhatsApp delivery through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# File uploads through Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public contact details used when the site config is first created
PUBLIC_CONTACT_EMAIL=hello@emberkids.com
PUBLIC_CONTACT_PHONE=
PUBLIC_CONTACT_PHONE_HREF=
PUBLIC_WHATSAPP_URL=
PUBLIC_INSTAGRAM_URL=https://www.instagram.com/emberkidsofficial
