{
  "name": "emberkids-backend",
  "version": "1.0.0",
  "description": "Backend API for EmberKids Chess Academy",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "npm run build && jest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node src/scripts/seed.ts",
    "init:collections": "ts-node src/scripts/initCollections.ts",
    "clear:database": "ts-node src/scripts/clearDatabase.ts",
    "create:admin": "ts-node src/scripts/createAdmin.ts",
    "check:admin-users": "ts-node src/scripts/checkAdminUsers.ts",
    "unlock:admin": "ts-node src/scripts/unlockAdmin.ts",
    "migrate:separate-auth": "ts-node src/scripts/migrateToSeparateAuth.ts",
    "fix:admin-passwords": "ts-node src/scripts/fixAdminPasswords.ts",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:dev": "npm audit --audit-level=moderate"
  },
  "keywords": [
    "chess",
    "academy",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/dompurify": "^3.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/redis": "^4.0.10",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.4.11",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "redis": "^6.1.0",
    "twilio": "^6.0.2",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
