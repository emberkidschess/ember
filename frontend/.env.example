# Public backend base URL, including the /api prefix
# For MilesWeb Shared Hosting: Backend on api.emberkidschess.com subdomain
NEXT_PUBLIC_API_URL=https://api.emberkidschess.com/api

# Required in production; internal routes fail closed when it is missing.
# Set this server-only value to an unguessable path and open that path first, e.g.
# https://emberkidschess.com/team-login-8f4c2a redirects to /login and unlocks
# /login, /admin/*, and /staff/* for 12 hours in that browser.
# DO NOT commit the actual value to version control.
INTERNAL_PORTAL_ENTRY_PATH=
